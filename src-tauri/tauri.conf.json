{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sorting-visualizer",
  "version": "0.1.0",
  "identifier": "com.sortingvisualizer.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npx serve ./dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sorting Visualizer",
        "width": 1400,
        "height": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
